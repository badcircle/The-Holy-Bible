Options -Indexes
RewriteEngine On

# If serving from a subdirectory (e.g. /Website/), set RewriteBase to match:
#   RewriteBase /Website/
# If serving from the root, leave as-is:
RewriteBase /

# ---------------------------------------------------------------------------
# Security — block sensitive paths before any other logic
# ---------------------------------------------------------------------------

# Bibles/ directory must never be served over HTTP (contains DB files)
RewriteRule ^Bibles/ - [F,L]

# Block dotfiles: .env, .git, .htaccess, .htpasswd, etc.
RewriteRule (^|/)\. - [F,L]

# Only these PHP entry points are valid; block everything else.
# This catches wp-login.php, xmlrpc.php, and all other PHP probes.
RewriteCond %{REQUEST_URI} \.php$
RewriteCond %{REQUEST_URI} !/index\.php$
RewriteCond %{REQUEST_URI} !/api\.php$
RewriteCond %{REQUEST_URI} !/search\.php$
RewriteRule ^ - [F,L]

# ---------------------------------------------------------------------------
# Pretty URL routing → index.php
# Real files (style.css, api.php) are served directly by Apache because
# the !-f condition below prevents them from being rewritten.
# ---------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# /trans/tid/book/ch/verse
RewriteRule ^([a-zA-Z]+)/([0-9]+)/([0-9]+)/([0-9]+)/([0-9]+)/?$ index.php?trans=$1&tid=$2&book=$3&ch=$4&verse=$5 [L,QSA]

# /trans/tid/book/ch
RewriteRule ^([a-zA-Z]+)/([0-9]+)/([0-9]+)/([0-9]+)/?$ index.php?trans=$1&tid=$2&book=$3&ch=$4 [L,QSA]

# /trans/tid/book
RewriteRule ^([a-zA-Z]+)/([0-9]+)/([0-9]+)/?$ index.php?trans=$1&tid=$2&book=$3&ch=1 [L,QSA]

# /trans/tid
RewriteRule ^([a-zA-Z]+)/([0-9]+)/?$ index.php?trans=$1&tid=$2 [L,QSA]

# /trans
RewriteRule ^([a-zA-Z]+)/?$ index.php?trans=$1 [L,QSA]
